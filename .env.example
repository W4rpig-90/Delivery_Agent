# ════════════════════════════════════════════════════════
#   DONATTO RESTO-BAR — Configuración
# ════════════════════════════════════════════════════════

BRAND_NAME=Donatto Resto-Bar
TIMEZONE=America/Bogota

# ─── KIOSKO (in-store) ──────────────────────────────────
KIOSK_ENABLED=true
KIOSK_PORT=3000

# Métodos de pago habilitados (separados por coma)
# Disponibles: efectivo, qr_transferencia, datafono
# Por ahora solo efectivo está activo. Los demás se muestran como "Próximamente".
KIOSK_PAYMENTS=efectivo

# Ruta al menú JSON. Por defecto apunta al menú en la carpeta hermana.
# MENU_PATH=/ruta/absoluta/a/donatto_menu.json

# ─── WHATSAPP ───────────────────────────────────────────
# Conector del bot. 'web' = whatsapp-web.js (QR, dev y prod en mini-PC local).
WHATSAPP_LOCAL_ENABLED=false
WHATSAPP_CONNECTOR=web
GEMINI_API_KEY=tu_api_key_aqui
DISPATCH_NUMBER=573104859728
BOT_NAME=Donatto Bot
BOT_PHONE=573203093949

# ─── NOTIFICACIÓN A DESPACHO (kiosko → cocina) ──────────
# Opción A (recomendada): webhook n8n. Cuando el kiosko genera un pedido,
# hace POST a este URL. n8n se encarga de notificar a WhatsApp y guardar en Sheets.
KIOSK_N8N_WEBHOOK_URL=

# Opción B (fallback): WhatsApp Cloud API directo. Requiere tener
# un Access Token y phone_number_id de Meta. Solo se usa si la Opción A falla.
META_ACCESS_TOKEN=
META_PHONE_NUMBER_ID=

# ─── IMPRESORA POS (opcional) ───────────────────────────
PRINTER_IP=
PRINTER_PORT=9100

# ─── BASE DE DATOS (V4) ─────────────────────────────────
# SQLite. Por defecto ./data/donattos.db (creada por `npm run db:migrate`).
DB_PATH=./data/donattos.db
ORDERS_LOG_PATH=./pedidos.log

# Ruta del menú JSON usado SOLO para sembrar la DB (npm run db:migrate).
# SEED_MENU_PATH=./data/menu.json

# ─── ADMIN INICIAL (seed) ───────────────────────────────
# Se crean solo si no existe ningún usuario. Cambia la contraseña tras el 1er login.
ADMIN_USERNAME=admin
ADMIN_INITIAL_PASSWORD=donatto2026

# Secreto para firmar las sesiones del panel. CÁMBIALO en producción
# (genera uno: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))")
SESSION_SECRET=
